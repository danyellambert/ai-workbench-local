# AI Decision Studio — local Docker Compose example.
# Copy to .env.docker.
# Do not commit real .env.docker.

AI_DECISION_STUDIO_DEPLOYMENT_TARGET=local_docker
AI_DECISION_STUDIO_DEPLOYMENT_MODE=oracle_like_compatible

AI_DECISION_STUDIO_FRONTEND_BIND_HOST=127.0.0.1
AI_DECISION_STUDIO_FRONTEND_PUBLIC_PORT=8071
AI_DECISION_STUDIO_PRODUCT_API_PUBLIC_PORT=8011

# Frontend build/runtime API contract for local Docker
VITE_PRODUCT_API_BASE_URL=/
VITE_PRODUCT_API_PROXY_ENABLED=0
VITE_PRODUCT_API_PROXY_TARGET=
APP_USERS_ROOT=/app/users

# Compatibility note: docker-compose.oracle-like.yml still reads ORACLE_DATA_ROOT.
AI_DECISION_STUDIO_DATA_ROOT=./runtime/ai_decision_studio_functional_baseline/oracle_like_data
AI_DECISION_STUDIO_ORACLE_DATA_ROOT=./runtime/ai_decision_studio_functional_baseline/oracle_like_data
AI_DECISION_STUDIO_BASELINE_ROOT=./runtime/ai_decision_studio_functional_baseline/oracle_like_data/baseline
AI_DECISION_STUDIO_RUNTIME_ROOT=./runtime/ai_decision_studio_functional_baseline/oracle_like_data/runtime
AI_DECISION_STUDIO_ARTIFACT_ROOT=./runtime/ai_decision_studio_functional_baseline/oracle_like_data/artifacts
AI_DECISION_STUDIO_USERS_ROOT=./runtime/ai_decision_studio_functional_baseline/oracle_like_data/users

PRODUCT_API_HOST=0.0.0.0
PRODUCT_API_PORT=8011
AI_DECISION_STUDIO_PRODUCT_API_HOST=0.0.0.0
AI_DECISION_STUDIO_PRODUCT_API_PORT=8011

OLLAMA_HOST=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=nemotron-3-super:cloud
OLLAMA_HOSTED_BASE_URL=https://ollama.com/api
OLLAMA_HOSTED_API_KEY=

HUGGINGFACE_INFERENCE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_INFERENCE_API_KEY=

PRESENTATION_EXPORT_ENABLED=true
PRESENTATION_EXPORT_BASE_URL=http://ppt-creator:8787
PRESENTATION_EXPORT_TIMEOUT_SECONDS=120
PRESENTATION_EXPORT_INCLUDE_REVIEW=true
PRESENTATION_EXPORT_PREVIEW_BACKEND=auto

EVIDENCEOPS_REPOSITORY_BACKEND=nextcloud_webdav
EVIDENCEOPS_NEXTCLOUD_BASE_URL=http://nextcloud/remote.php/dav/files/danyel
EVIDENCEOPS_NEXTCLOUD_USERNAME=danyel
EVIDENCEOPS_NEXTCLOUD_APP_PASSWORD=
EVIDENCEOPS_NEXTCLOUD_ROOT_PATH=/EvidenceOpsDemo

NEXTCLOUD_ADMIN_USER=danyel
NEXTCLOUD_ADMIN_PASSWORD=
NEXTCLOUD_TRUSTED_DOMAINS=localhost 127.0.0.1 nextcloud

AI_DECISION_STUDIO_ADMIN_USERNAME=admin
AI_DECISION_STUDIO_ADMIN_PASSWORD_HASH=
AI_DECISION_STUDIO_SESSION_SECRET=
AI_DECISION_STUDIO_PUBLIC_SESSION_MAX_MB=100

# Local Docker Nextcloud golden baseline restore
# The archive is runtime state outside Git. Do not commit the tarball.
AI_DECISION_STUDIO_NEXTCLOUD_GOLDEN_BASELINE_ARCHIVE=./runtime/ai_decision_studio_functional_baseline/nextcloud_golden_baseline/nextcloud-golden-baseline-v1.tar.gz
AI_DECISION_STUDIO_NEXTCLOUD_GOLDEN_BASELINE_SHA256=4dd4fb301249fa2ed6e6cc7e223df3beaed2a175b85c352b24ff3ca95636ddb2
AI_DECISION_STUDIO_NEXTCLOUD_GOLDEN_BASELINE_VOLUME=
AI_DECISION_STUDIO_NEXTCLOUD_GOLDEN_BASELINE_USER=danyel
AI_DECISION_STUDIO_NEXTCLOUD_GOLDEN_BASELINE_ROOT=/EvidenceOpsDemo

# Local Docker AI Lab golden state restore
# The archive is runtime state outside Git. Do not commit the tarball.
AI_DECISION_STUDIO_AI_LAB_GOLDEN_STATE_ARCHIVE=./runtime/ai_decision_studio_functional_baseline/ai_lab_golden_state/ai-lab-golden-state-v1.tar.gz
AI_DECISION_STUDIO_AI_LAB_GOLDEN_STATE_SHA256=c89628335dd1e6a9b9e177d202ab6492361d8b759bb22b41453ed0bc00253a5c
AI_DECISION_STUDIO_AI_LAB_GOLDEN_STATE_MARKER=runtime/cache/lab/.ai_lab_golden_state_v1_restored
