# AI Decision Studio — AWS single-VM deployment example.
# Copy to .env.aws on the AWS host and fill secrets there.
# Do not commit real .env.aws.
#
# This example intentionally mirrors the deployed AWS env key contract.
# Values are safe defaults/placeholders; real secrets stay only in .env.aws.
#
# Current AWS topology uses a single compose file:
# docker-compose.aws.yml

# Deployment identity
AI_DECISION_STUDIO_DEPLOYMENT_TARGET=aws
AI_DECISION_STUDIO_DEPLOYMENT_MODE=aws

# Host/public ports
AI_DECISION_STUDIO_FRONTEND_BIND_HOST=127.0.0.1
AI_DECISION_STUDIO_FRONTEND_PUBLIC_PORT=8071
AI_DECISION_STUDIO_PRODUCT_API_PUBLIC_PORT=8011
PRODUCT_API_HOST=0.0.0.0
PRODUCT_API_PORT=8011
AI_DECISION_STUDIO_PRODUCT_API_HOST=0.0.0.0
AI_DECISION_STUDIO_PRODUCT_API_PORT=8011

# Data roots
AI_DECISION_STUDIO_DATA_ROOT=/opt/ai-decision-studio/data
AI_DECISION_STUDIO_ORACLE_DATA_ROOT=/opt/ai-decision-studio/data
AI_DECISION_STUDIO_BASELINE_ROOT=/opt/ai-decision-studio/data/baseline
AI_DECISION_STUDIO_RUNTIME_ROOT=/opt/ai-decision-studio/data/runtime
AI_DECISION_STUDIO_ARTIFACT_ROOT=/opt/ai-decision-studio/data/artifacts
AI_DECISION_STUDIO_USERS_ROOT=/opt/ai-decision-studio/data/users
APP_BASELINE_ROOT=/app/baseline
APP_RUNTIME_ROOT=/app/runtime
APP_ARTIFACT_ROOT=/app/artifacts
APP_USERS_ROOT=/app/users
SQLITE_DATABASE=nextcloud

# Runtime resource controls
CUDA_VISIBLE_DEVICES=-1
ROCR_VISIBLE_DEVICES=-1
OLLAMA_CPUS=1
OLLAMA_MEM_LIMIT=2g
OLLAMA_MEMSWAP_LIMIT=3g
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1

# Providers
OLLAMA_HOST=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=nemotron-3-super:cloud
OLLAMA_HOSTED_BASE_URL=https://ollama.com/api
# Required for the hosted `*-cloud` generation models.
OLLAMA_HOSTED_API_KEY=
# Deploy-only: pre-pull this local Ollama embedding model into the sidecar volume.
AI_DECISION_STUDIO_OLLAMA_EMBEDDING_MODEL_PULL=embeddinggemma:300m
HUGGINGFACE_INFERENCE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_INFERENCE_API_KEY=

# Presentation export / PPT creator
PRESENTATION_EXPORT_ENABLED=true
PRESENTATION_EXPORT_BASE_URL=http://ppt-creator:8787
PRESENTATION_EXPORT_TIMEOUT_SECONDS=120
PRESENTATION_EXPORT_INCLUDE_REVIEW=true
PRESENTATION_EXPORT_PREVIEW_BACKEND=auto
PRESENTATION_EXPORT_FAIL_ON_REGRESSION=false
PRESENTATION_EXPORT_REQUIRE_REAL_PREVIEWS=false
PRESENTATION_EXPORT_REMOTE_OUTPUT_DIR=outputs/ai_workbench_exports
PRESENTATION_EXPORT_REMOTE_PREVIEW_DIR=outputs/ai_workbench_export_previews
PPT_CREATOR_AI_SERVICE_URL=http://product-api:8011

# EvidenceOps / Nextcloud
EVIDENCEOPS_REPOSITORY_BACKEND=nextcloud_webdav
EVIDENCEOPS_NEXTCLOUD_BASE_URL=http://nextcloud/remote.php/dav/files/ads_admin
EVIDENCEOPS_NEXTCLOUD_USERNAME=ads_admin
# Required for WebDAV import from Nextcloud; keep only in real .env.aws.
EVIDENCEOPS_NEXTCLOUD_APP_PASSWORD=
EVIDENCEOPS_NEXTCLOUD_ROOT_PATH=/EvidenceOpsDemo
EVIDENCEOPS_UI_CACHE_PATH=/app/runtime/cache/lab/evidenceops_payload.json
EVIDENCEOPS_UI_CACHE_MODE=persistent_until_sync
NEXTCLOUD_ADMIN_USER=ads_admin
# Required when Nextcloud initializes a fresh volume; keep only in real .env.aws.
NEXTCLOUD_ADMIN_PASSWORD=
NEXTCLOUD_TRUSTED_DOMAINS=localhost 127.0.0.1 nextcloud

# Auth/session
AI_DECISION_STUDIO_ADMIN_USERNAME=admin
AI_DECISION_STUDIO_ADMIN_PASSWORD_HASH=
AI_DECISION_STUDIO_SESSION_SECRET=
AI_DECISION_STUDIO_PUBLIC_SESSION_MAX_MB=150

# Trello
# API key/token are required for real Trello publish/sync.
EVIDENCEOPS_TRELLO_API_KEY=
EVIDENCEOPS_TRELLO_TOKEN=
EVIDENCEOPS_TRELLO_BOARD_ID='69deff16dda168171072e6d8'
EVIDENCEOPS_TRELLO_LIST_OPEN_ID='69deff16dda168171072e73f'
EVIDENCEOPS_TRELLO_LIST_REVIEW_ID='69deff16dda168171072e740'
EVIDENCEOPS_TRELLO_LIST_APPROVED_ID='69deff16dda168171072e741'
EVIDENCEOPS_TRELLO_LIST_DONE_ID='69deff7029a026d2ab3a1799'

# Notion
# API key must belong to a Notion integration with access to the configured database.
EVIDENCEOPS_NOTION_API_KEY=
EVIDENCEOPS_NOTION_DATABASE_ID='3431594b7fc080eebe5fdece0899b226'
EVIDENCEOPS_NOTION_PARENT_PAGE_ID=
EVIDENCEOPS_NOTION_API_VERSION=2022-06-28

# Vite API proxy mode
VITE_PRODUCT_API_PROXY_ENABLED=0
VITE_PRODUCT_API_PROXY_TARGET=

# AWS baseline restore artifacts.
# The app bundle intentionally stays code-only. These state artifacts are restored
# only when the target Nextcloud volume or AI Decision Studio data root is fresh/empty.
AI_DECISION_STUDIO_AWS_RESTORE_BASELINES=1
AI_DECISION_STUDIO_RESTORE_NEXTCLOUD_GOLDEN_BASELINE=1
AI_DECISION_STUDIO_FORCE_RESTORE_NEXTCLOUD_GOLDEN_BASELINE=0
AI_DECISION_STUDIO_NEXTCLOUD_GOLDEN_BASELINE_VOLUME=ai-decision-studio_nextcloud_app
AI_DECISION_STUDIO_NEXTCLOUD_GOLDEN_BASELINE_ARCHIVE=/opt/ai-decision-studio/golden_baseline/nextcloud-golden-baseline-v1.tar.gz
AI_DECISION_STUDIO_NEXTCLOUD_GOLDEN_BASELINE_SHA256=4dd4fb301249fa2ed6e6cc7e223df3beaed2a175b85c352b24ff3ca95636ddb2
AI_DECISION_STUDIO_RESTORE_PRODUCT_DATA_BASELINE=1
AI_DECISION_STUDIO_FORCE_RESTORE_PRODUCT_DATA_BASELINE=0
AI_DECISION_STUDIO_PRODUCT_DATA_BASELINE_ARCHIVE=/opt/ai-decision-studio/baselines/ai-decision-studio-product-data-baseline.tar.gz
AI_DECISION_STUDIO_PRODUCT_DATA_BASELINE_SHA256=c00741554086501c201c260988d1468ccb08f8ecf4fde79129697eb659904e45
AI_DECISION_STUDIO_PRODUCT_DATA_BASELINE_OWNER=ubuntu:ubuntu
AI_DECISION_STUDIO_AWS_CLEANUP_DEPLOY_TMP=1

# Public demo deck generation rate limit
# Applies only to POST /api/product/generate-deck for anonymous/public demo users.
# Admin/global requests bypass this limiter.
AI_DECISION_STUDIO_PUBLIC_DECK_RATE_LIMIT_ENABLED=true
AI_DECISION_STUDIO_PUBLIC_DECK_RATE_LIMIT_WINDOW_SECONDS=3600
AI_DECISION_STUDIO_PUBLIC_DECK_RATE_LIMIT_MAX_PER_SESSION=3
AI_DECISION_STUDIO_PUBLIC_DECK_RATE_LIMIT_MAX_PER_IP=12

# Public demo execution quota
# Applies only to anonymous/public workflow execution attempts.
# Admin/global execution bypasses this quota.
AI_DECISION_STUDIO_PUBLIC_EXECUTION_QUOTA_ENABLED=true
AI_DECISION_STUDIO_PUBLIC_EXECUTION_QUOTA_MAX_PER_SESSION=4
AI_DECISION_STUDIO_PUBLIC_EXECUTION_QUOTA_WINDOW_SECONDS=1200

# Public execution in-flight gate
# Limits simultaneous public runs to protect the shared AI runtime.
AI_DECISION_STUDIO_PUBLIC_EXECUTION_IN_FLIGHT_ENABLED=true
AI_DECISION_STUDIO_PUBLIC_EXECUTION_MAX_IN_FLIGHT_PER_SESSION=1
AI_DECISION_STUDIO_PUBLIC_EXECUTION_MAX_IN_FLIGHT_GLOBAL=2
AI_DECISION_STUDIO_PUBLIC_EXECUTION_IN_FLIGHT_TTL_SECONDS=300

# Public domain / reverse proxy
AI_DECISION_STUDIO_PUBLIC_DOMAIN=aidstudio.example.com

# Private credential store for Admin UI saved provider keys.
# This path must point to a private volume and must never be committed.
AI_DECISION_STUDIO_SECRET_STORE_BACKEND=file
AI_DECISION_STUDIO_SECRET_STORE_PATH=/app/secrets/credential_store.json
AI_DECISION_STUDIO_SECRET_ROOT=/opt/ai-decision-studio/secrets
