PROJECT_NAME=AI Workbench Local

# Ollama / modelos locais
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_AVAILABLE_MODELS=qwen2.5-coder:7b,deepseek-coder:6.7b
DEFAULT_PROMPT_PROFILE=neutro
OLLAMA_TEMPERATURE=0.2
OLLAMA_CONTEXT_WINDOW=8192
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_AVAILABLE_EMBEDDING_MODELS=bge-m3,nomic-embed-text,mxbai-embed-large
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4
RAG_RERANK_POOL_SIZE=8
RAG_RERANK_LEXICAL_WEIGHT=0.35
RAG_CONTEXT_BUDGET_RATIO=0.45
RAG_CONTEXT_CHARS_PER_TOKEN=4.0
RAG_CONTEXT_BUDGET_MIN_CHARS=1800
RAG_CONTEXT_BUDGET_MAX_CHARS=16000

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CONTEXT_WINDOW=128000
OPENAI_AVAILABLE_MODELS=gpt-4o-mini
