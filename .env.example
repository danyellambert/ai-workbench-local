PROJECT_NAME=AI Workbench Local
APP_LOG_LEVEL=INFO

# Gradio product surface
GRADIO_PRODUCT_APP_NAME=AI Workbench Product
GRADIO_PRODUCT_SERVER_NAME=127.0.0.1
GRADIO_PRODUCT_SERVER_PORT=7860
GRADIO_PRODUCT_THEME=premium_dark
GRADIO_PRODUCT_DEFAULT_WORKFLOW=document_review
GRADIO_PRODUCT_MAX_UPLOAD_FILES=6
GRADIO_PRODUCT_ENABLE_DECK_GENERATION=true
GRADIO_PRODUCT_SHOW_AI_LAB_ENTRY=true
GRADIO_PRODUCT_ACCENT_COLOR=#6ae3ff
GRADIO_PRODUCT_DEFAULT_DENSITY=comfortable

# Ollama / modelos locais
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
DEFAULT_PROMPT_PROFILE=neutro
OLLAMA_TEMPERATURE=0.2
OLLAMA_CONTEXT_WINDOW=8192
OLLAMA_TOP_P=
OLLAMA_MAX_TOKENS=
RAG_EMBEDDING_PROVIDER=ollama
RAG_EMBEDDING_MODEL=
RAG_EMBEDDING_CONTEXT_WINDOW=512
RAG_EMBEDDING_TRUNCATE=true
OLLAMA_EMBEDDING_MODEL=embeddinggemma:300m
OLLAMA_EMBEDDING_CONTEXT_WINDOW=512
RAG_LOADER_STRATEGY=manual
RAG_CHUNKING_STRATEGY=manual
RAG_RETRIEVAL_STRATEGY=manual_hybrid
OLLAMA_HTTP_TIMEOUT_SECONDS=300
OLLAMA_EMBED_BATCH_SIZE=16
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=80
RAG_TOP_K=4
RAG_RERANK_POOL_SIZE=8
RAG_RERANK_LEXICAL_WEIGHT=0.35
RAG_CONTEXT_BUDGET_RATIO=0.45
RAG_CONTEXT_CHARS_PER_TOKEN=4.0
RAG_CONTEXT_BUDGET_MIN_CHARS=1800
RAG_CONTEXT_BUDGET_MAX_CHARS=16000
RAG_PDF_EXTRACTION_MODE=hybrid
RAG_PDF_BASELINE_CHARS_PER_PAGE_THRESHOLD=90
RAG_PDF_MIN_TEXT_COVERAGE_RATIO=0.65
RAG_PDF_SUSPICIOUS_IMAGE_COUNT_THRESHOLD=1
RAG_PDF_SUSPICIOUS_IMAGE_AREA_RATIO=0.18
RAG_PDF_SUSPICIOUS_LOW_TEXT_CHARS=220
RAG_PDF_SUSPICIOUS_PAGE_SCORE_THRESHOLD=0.85
RAG_PDF_SUSPICIOUS_PAGES_TRIGGER_FULL_DOCLING_RATIO=0.45
RAG_PDF_SUSPICIOUS_PAGES_TRIGGER_FULL_DOCLING_MIN_COUNT=6
RAG_PDF_MAX_SELECTIVE_DOCLING_PAGES=12
RAG_PDF_DOCLING_ENABLED=true
RAG_PDF_DOCLING_OCR_ENABLED=true
RAG_PDF_DOCLING_FORCE_FULL_PAGE_OCR=false
RAG_PDF_DOCLING_PICTURE_DESCRIPTION=false
RAG_PDF_EVIDENCE_PIPELINE_ENABLED=true
RAG_PDF_EVIDENCE_PIPELINE_USE_FOR_CV_LIKE=true
RAG_PDF_EVIDENCE_PIPELINE_USE_FOR_STRONG_SCAN_LIKE=true
RAG_PDF_EVIDENCE_PIPELINE_ROLLOUT_PERCENTAGE=100
EVIDENCE_OCR_BACKEND=ocrmypdf
EVIDENCE_VL_MODEL=sorc/qwen3.5-instruct:2b

# Executive Deck Generation (P1 — benchmark/eval executive review)
# Caminho recomendado agora: subir o renderer do `ppt_creator_app` nativamente no host.
PRESENTATION_EXPORT_ENABLED=true
PRESENTATION_EXPORT_BASE_URL=http://127.0.0.1:8787
PRESENTATION_EXPORT_TIMEOUT_SECONDS=120
PRESENTATION_EXPORT_REMOTE_OUTPUT_DIR=outputs/ai_workbench_exports
PRESENTATION_EXPORT_REMOTE_PREVIEW_DIR=outputs/ai_workbench_export_previews
PRESENTATION_EXPORT_LOCAL_ARTIFACT_DIR=/Users/danyellambert/Downloads/Aula 4 - Criacao de Chatbot com IA em Tempo Real/artifacts/presentation_exports
PRESENTATION_EXPORT_INCLUDE_REVIEW=true
PRESENTATION_EXPORT_PREVIEW_BACKEND=auto
PRESENTATION_EXPORT_REQUIRE_REAL_PREVIEWS=false
PRESENTATION_EXPORT_FAIL_ON_REGRESSION=false
# opcional: vazio = todos os deck types habilitados; também aceita aliases de produto, ex. benchmark_eval_executive_review
PRESENTATION_EXPORT_ENABLED_EXPORT_KINDS=
PPT_CREATOR_APP_ROOT=/Users/danyellambert/ppt_creator_app
PPT_CREATOR_APP_PYTHON_BIN=/Users/danyellambert/ppt_creator_app/.conda-env/bin/python
PPT_CREATOR_APP_HOST=127.0.0.1
PPT_CREATOR_APP_PORT=8787
PPT_CREATOR_APP_ASSET_ROOT=/Users/danyellambert/ppt_creator_app/examples

