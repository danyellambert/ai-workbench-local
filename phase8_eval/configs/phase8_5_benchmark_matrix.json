              "structured_output_mode": "bullet_prompt_contract",
              "input_file": "phase5_eval/fixtures/02_summary_input.txt",
              "prompt_template": "Use only the information below.\n\n{input_text}\n\nSummarize the main points, risks, and next steps in concise bullets."
            },
            {
              "use_case_id": "release_candidate_risk_review",
              "label": "Release candidate risk review",
              "benchmark_use_case": "risk_review",
              "prompt_profile": "neutro",
              "response_format": "bullet_list",
              "structured_output_mode": "bullet_prompt_contract",
              "input_file": "phase5_eval/fixtures/03_checklist_input.txt",
              "prompt_template": "Use only the information below.\n\n{input_text}\n\nIdentify the main risks, blockers, controls, and recommended next steps in bullets."
            },
            {
              "use_case_id": "cv_structured_extraction",
              "label": "CV structured extraction",
