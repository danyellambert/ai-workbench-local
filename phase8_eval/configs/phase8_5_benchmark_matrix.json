  "timeout_policy": {
    "generation_case_timeout_s": 180,
    "embedding_indexing_timeout_s": 600,
    "embedding_query_timeout_s": 180,
    "provider_transport_timeout_source": "native_provider_timeout"
  },
  "output_directory_policy": {
    "root_dir": "benchmark_runs/phase8_5_round1",
    "run_dir_strategy": "stable_run_id",
    "raw_dir": "raw",
    "normalized_dir": "normalized",
    "aggregated_dir": "aggregated",
    "case_dir": "cases",
    "prevent_overwrite_without_resume": true
