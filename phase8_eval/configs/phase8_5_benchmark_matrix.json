              "structured_output_mode": "json_prompt_contract",
              "input_file": "phase5_eval/fixtures/04_cv_sample.txt",
              "prompt_template": "Use only the CV content below.\n\n{input_text}\n\nExtract the most relevant information as JSON with keys: summary, risks, actions, entities."
            },
            {
              "use_case_id": "code_quality_review",
              "label": "Code quality review",
              "benchmark_use_case": "technical_review",
              "prompt_profile": "programador",
              "response_format": "bullet_list",
              "structured_output_mode": "bullet_prompt_contract",
              "input_file": "phase5_eval/fixtures/05_code_sample.py",
              "prompt_template": "Use only the code below.\n\n{input_text}\n\nExplain the main technical issues, impacts, and prioritized recommendations in bullets."
            }
          ]
        }
      ],
      "smoke_limits": {
        "max_provider_model_pairs": 1,
        "max_use_cases": 2,
        "repetitions": 1
