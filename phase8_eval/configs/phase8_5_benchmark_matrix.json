{
  "benchmark_id": "phase8_5_round1",
  "manifest_version": "1.0",
  "description": "Phase 8.5 benchmark matrix for local generation/runtime, embeddings, rerankers, and OCR/VLM fallback comparisons.",
  "groups": {
    "generation": {
      "enabled": true,
      "repetitions": 2,
