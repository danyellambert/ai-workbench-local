# AI Decision Studio — local host/dev example.
# Copy to .env.local or adapt your existing legacy .env.
# Do not commit real .env.local or .env.

PROJECT_NAME=AI Decision Studio
APP_LOG_LEVEL=INFO

PRODUCT_API_SERVER_NAME=127.0.0.1
PRODUCT_API_SERVER_PORT=8011
PRODUCT_API_ENABLE_WEB_FRONTEND=true
PRODUCT_API_ALLOW_CORS=true
VITE_PRODUCT_API_BASE_URL=http://127.0.0.1:5173

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=nemotron-3-super:cloud
OLLAMA_HOSTED_BASE_URL=https://ollama.com/api
OLLAMA_HOSTED_API_KEY=

HUGGINGFACE_INFERENCE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_INFERENCE_API_KEY=

PRESENTATION_EXPORT_ENABLED=true
PRESENTATION_EXPORT_BASE_URL=http://127.0.0.1:8787
PRESENTATION_EXPORT_TIMEOUT_SECONDS=120
PRESENTATION_EXPORT_LOCAL_ARTIFACT_DIR=artifacts/presentation_exports

EVIDENCEOPS_REPOSITORY_BACKEND=local
EVIDENCEOPS_CORPUS_PRIMARY_ROOT=data/corpus_revisado/option_b_synthetic_premium
EVIDENCEOPS_CORPUS_PUBLIC_ROOT=data/corpus_revisado/option_a_public_corpus_v2

# Optional private Nextcloud tunnel from your Mac.
EVIDENCEOPS_NEXTCLOUD_BASE_URL=http://127.0.0.1:8085/remote.php/dav/files/<username>
EVIDENCEOPS_NEXTCLOUD_USERNAME=
EVIDENCEOPS_NEXTCLOUD_APP_PASSWORD=
EVIDENCEOPS_NEXTCLOUD_ROOT_PATH=/EvidenceOpsDemo

EVIDENCEOPS_TRELLO_API_KEY=
EVIDENCEOPS_TRELLO_TOKEN=
EVIDENCEOPS_TRELLO_BOARD_ID=
EVIDENCEOPS_TRELLO_LIST_OPEN_ID=
EVIDENCEOPS_TRELLO_LIST_REVIEW_ID=
EVIDENCEOPS_TRELLO_LIST_APPROVED_ID=
EVIDENCEOPS_TRELLO_LIST_DONE_ID=

EVIDENCEOPS_NOTION_API_KEY=
EVIDENCEOPS_NOTION_DATABASE_ID=
EVIDENCEOPS_NOTION_PARENT_PAGE_ID=
EVIDENCEOPS_NOTION_API_VERSION=2022-06-28

# Local host/dev overrides
AI_DECISION_STUDIO_DEPLOYMENT_TARGET=local
AI_DECISION_STUDIO_DEPLOYMENT_MODE=local_dev
PRODUCT_API_HOST=127.0.0.1
PRODUCT_API_PORT=8011
AI_DECISION_STUDIO_PRODUCT_API_HOST=127.0.0.1
AI_DECISION_STUDIO_PRODUCT_API_PORT=8011
APP_USERS_ROOT=runtime/local_dev/users
AI_DECISION_STUDIO_USERS_ROOT=runtime/local_dev/users
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173

# Local host/dev runtime contract
AI_DECISION_STUDIO_PRODUCT_API_PUBLIC_PORT=8011
PPT_CREATOR_AI_SERVICE_URL=http://127.0.0.1:8011
AI_DECISION_STUDIO_PUBLIC_SESSION_MAX_MB=150
AI_DECISION_STUDIO_ADMIN_USERNAME=admin
AI_DECISION_STUDIO_SESSION_SECRET=
AI_DECISION_STUDIO_ADMIN_PASSWORD_HASH=

# Local Vite same-origin proxy
VITE_PRODUCT_API_PROXY_ENABLED=1
VITE_PRODUCT_API_PROXY_TARGET=http://127.0.0.1:8011

# Optional local app/runtime overrides
# Optional local-development paths and prompt defaults.
# Defaults in code should be enough for the current green gate; override only when needed.
APP_RUNTIME_ROOT=runtime/local_dev
APP_ARTIFACT_ROOT=runtime/local_dev/artifacts
DEFAULT_PROMPT_PROFILE=balanced

# Optional local provider settings
# Optional provider placeholders for local development.
# Do not commit real API keys. Leave blank to use local/default provider behavior.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=1200
OPENAI_TOP_P=1
OPENAI_CONTEXT_WINDOW=128000
OPENAI_AVAILABLE_MODELS=gpt-4o-mini,gpt-4o
OPENAI_AVAILABLE_EMBEDDING_MODELS=text-embedding-3-small,text-embedding-3-large
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBED_BATCH_SIZE=16
OLLAMA_CONTEXT_WINDOW=8192
OLLAMA_EMBEDDING_CONTEXT_WINDOW=8192
OLLAMA_MAX_TOKENS=1200
OLLAMA_TEMPERATURE=0.2
OLLAMA_TOP_P=0.9
OLLAMA_HTTP_TIMEOUT_SECONDS=120
OLLAMA_HOSTED_MODEL=
OLLAMA_HOSTED_AVAILABLE_MODELS=
OLLAMA_HOSTED_AVAILABLE_EMBEDDING_MODELS=
OLLAMA_HOSTED_CONTEXT_WINDOW=
OLLAMA_HOSTED_MAX_TOKENS=
OLLAMA_HOSTED_TEMPERATURE=
OLLAMA_HOSTED_TOP_P=

# Optional local RAG/document settings
# Optional retrieval/document-processing knobs used by current product code.
# Safe defaults are provided for local development; tune only when debugging retrieval behavior.
RAG_RETRIEVAL_STRATEGY=hybrid
RAG_TOP_K=8
RAG_RERANK_POOL_SIZE=24
RAG_RERANK_LEXICAL_WEIGHT=0.35
RAG_CHUNKING_STRATEGY=semantic
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=180
RAG_CONTEXT_BUDGET_MAX_CHARS=12000
RAG_CONTEXT_BUDGET_MIN_CHARS=3000
RAG_CONTEXT_BUDGET_RATIO=0.65
RAG_CONTEXT_CHARS_PER_TOKEN=4
RAG_EMBEDDING_PROVIDER=ollama
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_EMBEDDING_CONTEXT_WINDOW=8192
RAG_EMBEDDING_TRUNCATE=1
RAG_LOADER_STRATEGY=auto
RAG_PDF_EXTRACTION_MODE=auto
RAG_PDF_DOCLING_ENABLED=0
RAG_PDF_DOCLING_OCR_ENABLED=0
RAG_PDF_DOCLING_FORCE_FULL_PAGE_OCR=0
RAG_PDF_DOCLING_PICTURE_DESCRIPTION=0
RAG_PDF_MAX_SELECTIVE_DOCLING_PAGES=12
RAG_PDF_MIN_TEXT_COVERAGE_RATIO=0.2
RAG_PDF_BASELINE_CHARS_PER_PAGE_THRESHOLD=400
RAG_PDF_SUSPICIOUS_LOW_TEXT_CHARS=120
RAG_PDF_SUSPICIOUS_IMAGE_COUNT_THRESHOLD=3
RAG_PDF_SUSPICIOUS_IMAGE_AREA_RATIO=0.45
RAG_PDF_SUSPICIOUS_PAGE_SCORE_THRESHOLD=0.7
RAG_PDF_SUSPICIOUS_PAGES_TRIGGER_FULL_DOCLING_MIN_COUNT=3
RAG_PDF_SUSPICIOUS_PAGES_TRIGGER_FULL_DOCLING_RATIO=0.35
RAG_PDF_EVIDENCE_PIPELINE_ENABLED=0
RAG_PDF_EVIDENCE_PIPELINE_ROLLOUT_PERCENTAGE=0
RAG_PDF_EVIDENCE_PIPELINE_USE_FOR_CV_LIKE=0
RAG_PDF_EVIDENCE_PIPELINE_USE_FOR_STRONG_SCAN_LIKE=0

# Optional presentation export settings
# Optional presentation/deck export settings for local development.
# Remote output directories should stay blank unless using a private renderer host.
PRESENTATION_EXPORT_PREVIEW_BACKEND=local
PRESENTATION_EXPORT_INCLUDE_REVIEW=1
PRESENTATION_EXPORT_FAIL_ON_REGRESSION=0
PRESENTATION_EXPORT_REQUIRE_REAL_PREVIEWS=0
PRESENTATION_EXPORT_REMOTE_OUTPUT_DIR=
PRESENTATION_EXPORT_REMOTE_PREVIEW_DIR=

# Optional EvidenceOps/preindex settings
# Optional EvidenceOps and preindex placeholders.
# External sync is disabled by default; keep secrets only in private .env.local.
EVIDENCEOPS_EXTERNAL_SYNC_ENABLED=0
EVIDENCEOPS_PREINDEX_FAST_IMPORT_ENABLED=1
EVIDENCEOPS_PREINDEX_RESUME=1
EVIDENCEOPS_PREINDEX_STORE_PATH=
EVIDENCEOPS_PREINDEX_CHECKPOINT_DIR=
EVIDENCEOPS_PREINDEX_SYNC_CHROMA_ON_IMPORT=0
EVIDENCEOPS_PREINDEX_SIM_CURVE=linear
EVIDENCEOPS_PREINDEX_SIM_MIN_SECONDS=0
EVIDENCEOPS_PREINDEX_SIM_MAX_SECONDS=0
EVIDENCE_OCR_BACKEND=auto
EVIDENCE_VL_MODEL=

# Public demo execution quota
# Applies only to anonymous/public workflow execution attempts.
# Admin/global execution bypasses this quota.
AI_DECISION_STUDIO_PUBLIC_EXECUTION_QUOTA_ENABLED=true
AI_DECISION_STUDIO_PUBLIC_EXECUTION_QUOTA_MAX_PER_SESSION=20
