# AI Decision Studio — local host/dev example.
# Copy to .env.local or adapt your existing legacy .env.
# Do not commit real .env.local or .env.

PROJECT_NAME=AI Workbench Local
APP_LOG_LEVEL=INFO
APP_RUNTIME_ROOT=.runtime
APP_ARTIFACT_ROOT=artifacts

PRODUCT_API_SERVER_NAME=127.0.0.1
PRODUCT_API_SERVER_PORT=8011
PRODUCT_API_ENABLE_WEB_FRONTEND=true
PRODUCT_API_ALLOW_CORS=true
VITE_PRODUCT_API_BASE_URL=http://127.0.0.1:8011

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=nemotron-3-super:cloud
OLLAMA_HOSTED_BASE_URL=https://ollama.com/api
OLLAMA_HOSTED_API_KEY=

HUGGINGFACE_INFERENCE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_INFERENCE_API_KEY=

PRESENTATION_EXPORT_ENABLED=true
PRESENTATION_EXPORT_BASE_URL=http://127.0.0.1:8787
PRESENTATION_EXPORT_TIMEOUT_SECONDS=120
PRESENTATION_EXPORT_LOCAL_ARTIFACT_DIR=artifacts/presentation_exports

EVIDENCEOPS_REPOSITORY_BACKEND=local
EVIDENCEOPS_CORPUS_PRIMARY_ROOT=data/corpus_revisado/option_b_synthetic_premium
EVIDENCEOPS_CORPUS_PUBLIC_ROOT=data/corpus_revisado/option_a_public_corpus_v2

# Optional private Nextcloud tunnel from your Mac.
EVIDENCEOPS_NEXTCLOUD_BASE_URL=http://127.0.0.1:8085/remote.php/dav/files/<username>
EVIDENCEOPS_NEXTCLOUD_USERNAME=
EVIDENCEOPS_NEXTCLOUD_APP_PASSWORD=
EVIDENCEOPS_NEXTCLOUD_ROOT_PATH=/EvidenceOpsDemo

EVIDENCEOPS_TRELLO_API_KEY=
EVIDENCEOPS_TRELLO_TOKEN=
EVIDENCEOPS_TRELLO_BOARD_ID=
EVIDENCEOPS_TRELLO_LIST_OPEN_ID=
EVIDENCEOPS_TRELLO_LIST_REVIEW_ID=
EVIDENCEOPS_TRELLO_LIST_APPROVED_ID=
EVIDENCEOPS_TRELLO_LIST_DONE_ID=

EVIDENCEOPS_NOTION_API_KEY=
EVIDENCEOPS_NOTION_DATABASE_ID=
EVIDENCEOPS_NOTION_PARENT_PAGE_ID=
EVIDENCEOPS_NOTION_API_VERSION=2022-06-28
