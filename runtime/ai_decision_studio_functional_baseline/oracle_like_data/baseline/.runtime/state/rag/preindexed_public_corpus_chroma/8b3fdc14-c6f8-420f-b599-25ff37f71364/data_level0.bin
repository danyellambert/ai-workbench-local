ed_structured_sections":[],"dropped_section_reasons":[],"raw_text_present":true,"structured_payload_usable":true},"included_structured_sections":["confirmed_fields","education"],"dropped_structured_sections":[],"dropped_section_reasons":[],"routing_diagnostics":{"feature_flag_enabled":true,"filename_hint":true,"cv_like_content_detected":true,"cv_like_reasons":["top_contact_profile_structure","cv_like_sections_detected","resume_like_date_ranges","sufficient_resume_like_content"],"strong_scan_like":false,"rollout_percentage":100,"rollout_bucket":47,"rollout_selected":true,"decision":"evidence_path","reason":"cv_like_match"},"hybrid_contact_policy":{"emails":["francisjtaylor@gmail.com"],"phones":["617-343-0338"],"name":"Francis B. Taylor","location":"67 Richdale Ave, Cincinatti, OH 45201","policy":{"emails":"legacy_confirmed_first_fill_from_evidence_confirmed","phones":"legacy_confirmed_first_fill_from_evidence_confirmed","name":"use_evidence_confirmed_only","location":"use_evidence_confirmed_only"},"stats":{"email_complements":1,"phone_complements":1,"email_conflicts":0,"phone_conflicts":0}},"shadow_rollout":{"agreements":0,"email_complements":1,"phone_complements":1,"email_conflicts":0,"phone_conflicts":0},"legacy_shadow_reference":{"extractor":"pdf_hybrid","strategy":"hybrid"},"fallback_available":true,"loader_strategy_requested":"manual","loader_strategy_used":"manual","loader_strategy_label":"Local manual","size_bytes":140330,"grounding_text_excerpt":"[CV CONFIRMED FIELDS]\nName: Francis B. Taylor\nLocation: 67 Richdale Ave, Cincinatti, OH 45201\nEmails: francisjtaylor@gmail.com\nPhones: 617-343-0338\n\n[CV EDUCATION]\n- Bachelor of Science | Creighton University, Omaha, NE May 2019 | Creighton University, Omaha, NE May 2019 | Bachelor of Science, Biochemistry\n  • Awards: Phi Beta Kappa, Magna Cum Laude\n- Bachelor of Science | Biochemistry | Awards: Phi Beta Kappa, Magna Cum Laude\n  • Bachelor of Science, Biochemistry\n- Creighton University Department of Chemistry, Omaha, NE August 2016— May 2019 | Creighton University Department of Chemistry, Omaha, NE August 2016— May 2019 | Teaching Assistant\n  • Assisted in the design of lectures, assignments, quizzes, and laboratory manuals for General\n- Creighton University Admissions Office, Omaha, NE Summer 2016, 2017, 2018 | Creighton University Admissions Office, Omaha, NE Summer 2016, 2017, 2018 | Admissions Fellow\n  • Conducted interviews with prospective applicants and produced written evaluations for the\n  • admissions committee.\n\n[CV RAW TEXT]\nFrancis B. Taylor 67 Richdale Ave, Cincinatti, OH 